# .env.example
# Copia este archivo como .env y reemplaza los valores con las credenciales
# de tu proyecto en Supabase. El archivo .env real está ignorado por git.
# NUNCA subas credenciales reales al repositorio.

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
