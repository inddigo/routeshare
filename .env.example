# .env.example
# Reemplaza los valores con las credenciales de tu proyecto en Supabase.
# NUNCA subas el archivo .env real al repositorio (.gitignore ya debe estar configurado).

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJh...tu-anon-key...

# Nota: Aunque estemos en React Native CLI, usamos EXPO_PUBLIC si usáramos Expo,
# pero para RN CLI podemos usar 'react-native-dotenv' o similar.
# Como no especificaste libería de env, usaremos SUPABASE_URL genérico.
